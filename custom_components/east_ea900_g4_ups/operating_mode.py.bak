"""System operating mode (input register 71) — enum state keys and lookup."""

from __future__ import annotations

from typing import Final

# Internal state strings for SensorDeviceClass.ENUM (English keys; UI via translations).
SYSTEM_OPERATING_MODE_OPTIONS: Final[tuple[str, ...]] = (
    "unknown",
    "standby_mode",
    "bypass_mode",
    "online_mode",
    "battery_mode",
    "test_battery_mode",
    "fault_mode",
    "fixed",
    "mode_0",
    "mode_1",
    "mode_9",
    "mode_10",
    "mode_extended",
)


def system_operating_mode_state(mode: int | None) -> str:
    """Map raw register value to a fixed ENUM option id.

    Known codes (field observation): 2 standby, 3 bypass, 4 online, 5 battery, 6 battery test, 7 fault, 8 fixed-frequency_mode.
    Other values 0–10 use mode_<n> except 2-8 which use the known names.
    Values outside 0–10 map to mode_extended (raw code in entity attributes).
    """
    if mode is None:
        return "unknown"
    if mode == 2:
        return "standby_mode"
    if mode == 3:
        return "bypass_mode"
    if mode == 4:
        return "online_mode"
    if mode == 5:
        return "battery_mode"
    if mode == 6:
        return "test_battery_mode"
    if mode == 7:
        return "fault_mode"
    if mode == 8:
        return "fixed-frequency_mode"
    if mode in (0, 1, 9, 10):
        return f"mode_{mode}"
    return "mode_extended"
